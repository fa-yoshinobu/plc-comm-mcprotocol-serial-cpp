PROJECT_NAME           = "MC Protocol Serial C++"
PROJECT_NUMBER         = "0.2.3"
PROJECT_BRIEF          = "MC protocol serial library for MCU-oriented environments"
OUTPUT_DIRECTORY       = "@CMAKE_BINARY_DIR@/docs"
CREATE_SUBDIRS         = NO

INPUT                  = "@CMAKE_SOURCE_DIR@/README.md" \
                         "@CMAKE_SOURCE_DIR@/CHANGELOG.md" \
                         "@CMAKE_SOURCE_DIR@/include" \
                         "@CMAKE_SOURCE_DIR@/docsrc" \
                         "@CMAKE_SOURCE_DIR@/examples"
FILE_PATTERNS          = *.md *.hpp *.h *.cpp
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */build/*

USE_MDFILE_AS_MAINPAGE = "@CMAKE_SOURCE_DIR@/README.md"
MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 2

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = api
GENERATE_TREEVIEW      = YES
GENERATE_LATEX         = NO
HAVE_DOT               = NO

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_FROM_PATH        = "@CMAKE_SOURCE_DIR@"
FULL_PATH_NAMES        = YES

EXAMPLE_PATH           = "@CMAKE_SOURCE_DIR@/examples"
EXAMPLE_RECURSIVE      = YES

QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
